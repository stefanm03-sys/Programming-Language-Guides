{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lua",
      "request": "launch",
      "name": "Lua: Active File",
      "program": "${file}"
    },
    {
      "type": "python",
      "request": "launch",
      "name": "Python: Active File",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "type": "java",
      "request": "launch",
      "name": "Java: Active File",
      "mainClass": "${fileBasenameNoExtension}",
      "cwd": "${fileDirname}",
      "classPaths": [
        "${fileDirname}"
      ]
    },
    {
      "type": "pwa-node",
      "request": "launch",
      "name": "Node: Active JS File",
      "program": "${file}",
      "cwd": "${fileDirname}"
    },
    {
      "type": "pwa-chrome",
      "request": "launch",
      "name": "Chrome: practice.html",
      "url": "file://${workspaceFolder}/Web Design/practice.html",
      "webRoot": "${workspaceFolder}"
    }
  ]
}
